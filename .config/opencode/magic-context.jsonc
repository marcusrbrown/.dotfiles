{
  "$schema": "https://raw.githubusercontent.com/cortexkit/opencode-magic-context/master/assets/magic-context.schema.json",
  "historian": {
    "model": "anthropic/claude-sonnet-4-6"
  },
  "dreamer": {
    "enabled": true,
    "model": "anthropic/claude-sonnet-4-6"
  },
  "sidekick": {
    "enabled": true,
    "model": "opencode/gpt-5-nano"
  },
  "cache_ttl": {
    "default": "5m",
    "anthropic/claude-sonnet-4-6": "59m",
    "anthropic/claude-opus-4-6": "59m"
  },
  "execute_threshold_percentage": {
    "default": 65,
    "anthropic/claude-sonnet-4-6": 40,
    "anthropic/claude-opus-4-6": 40
  },
  "experimental": {
    "pin_key_files": {
      "enabled": true,
      "token_budget": 10000,
      "min_reads": 4
    },
    "user_memories": {
      "enabled": true,
      "promotion_threshold": 3
    }
  }
}