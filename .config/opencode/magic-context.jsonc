{
  "$schema": "https://raw.githubusercontent.com/cortexkit/magic-context/master/assets/magic-context.schema.json",
  "historian": {
    "model": "openai/gpt-5.4-mini",
    "fallback_models": ["anthropic/claude-sonnet-4-6", "github-copilot/claude-sonnet-4.6"],
    "temperature": 0.1,
    "variant": "medium",
    "tools": {
      "bash": false,
      "write": false,
      "edit": false
    },
    "permission": {
      "bash": "deny",
      "webfetch": "deny",
      "edit": "deny"
    }
  },
  "dreamer": {
    "enabled": true,
    "model": "openai/gpt-5.4-mini",
    "fallback_models": ["anthropic/claude-sonnet-4-6", "github-copilot/claude-sonnet-4.6"],
    "schedule": "00:00-08:00",
    "user_memories": {
      "enabled": true,
      "promotion_threshold": 3
    },
    "pin_key_files": {
      "enabled": true,
      "token_budget": 20000,
      "min_reads": 4
    }
  },
  "sidekick": {
    "enabled": true,
    "model": "openai/gpt-5.4-mini",
    "fallback_models": ["anthropic/claude-haiku-4-5"],
    "temperature": 0.1,
    "variant": "low",
    "timeout_ms": 30000
  },
  "cache_ttl": {
    "default": "5m",
    "anthropic/claude-sonnet-4-6": "59m",
    "anthropic/claude-opus-4-6": "59m",
    "anthropic/claude-opus-4-7": "59m"
  },
  "execute_threshold_percentage": {
    "default": 65,
    "anthropic/claude-sonnet-4-6": 55,
    "anthropic/claude-opus-4-6": 55,
    "anthropic/claude-opus-4-7": 55,
    "openai/gpt-5.5": 50,
    "openai/gpt-5.4": 60,
    "openai/gpt-5.4-mini": 65
  },
  "execute_threshold_tokens": {
    "github-copilot/claude-opus-4.7": 80000,
    "github-copilot/claude-sonnet-4.6": 95000
  },
  "experimental": {
    "auto_search": {
      "enabled": true,
      "min_prompt_chars": 20,
      "score_threshold": 0.55
    },
    "git_commit_indexing": {
      "enabled": true,
      "since_days": 365,
      "max_commits": 2000
    },
    "temporal_awareness": true,
    "caveman_text_compression": {
      "enabled": true
    }
  },
  "history_budget_percentage": 0.15,
  "historian_timeout_ms": 420000,
  "memory": {
    "injection_budget_tokens": 6000
  },
  "compaction_markers": true,
  "auto_drop_tool_age": 30,
  "ctx_reduce_enabled": false,
  "system_prompt_injection": {
    "enabled": true,
    "skip_signatures": ["You are the Council agent — a multi-LLM"]
  }
}
