{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@cortexkit/opencode-anthropic-auth@1.13.0",
    "oh-my-opencode-slim@1.1.2",
    "@cortexkit/opencode-magic-context@0.31.0",
    "@cortexkit/aft-opencode@0.45.1",
    "@fro.bot/systematic@2.33.2"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "oauth": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "oauth": false
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}&tools=web_search_exa",
      "oauth": false
    }
  },
  "agent": {
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "experimental": {
    "openTelemetry": false
  },
  "lsp": true
}
