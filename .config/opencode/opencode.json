{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@cortexkit/opencode-anthropic-auth@1.1.2",
    "oh-my-opencode-slim@1.1.1",
    "@cortexkit/opencode-magic-context@0.21.1",
    "@cortexkit/aft-opencode@0.26.4",
    "opencode-copilot-delegate@0.12.0",
    "@fro.bot/systematic@2.20.0"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "oauth": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "discord": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "DISCORD_TOKEN",
        "-e",
        "DISCORD_GUILD_ID",
        "saseq/discord-mcp:1.0.0"
      ],
      "environment": {
        "DISCORD_TOKEN": "{env:DISCORD_TOKEN}",
        "DISCORD_GUILD_ID": "{env:DISCORD_GUILD_ID}"
      },
      "enabled": false,
      "timeout": 30000
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "oauth": false
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "oauth": false
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}&tools=web_search_exa",
      "oauth": false
    }
  },
  "agent": {
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "model": "opencode-go/kimi-k2.6",
  "compaction": {
    "auto": false,
    "prune": false
  },
  "experimental": {
    "openTelemetry": false
  },
  "lsp": true
}
