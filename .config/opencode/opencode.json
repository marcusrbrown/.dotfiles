{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "opencode-copilot-delegate@0.11.0",
    "@fro.bot/systematic@2.7.2",
    "@franlol/opencode-md-table-formatter@0.0.6",
    "@cortexkit/opencode-magic-context@0.15.7",
    "@cortexkit/aft-opencode@0.19.0",
    "oh-my-opencode-slim@1.0.6"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "oauth": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "oauth": false
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "oauth": false
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}&tools=web_search_exa",
      "oauth": false
    }
  },
  "agent": {
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "model": "opencode-go/kimi-k2.6",
  "compaction": {
    "auto": false,
    "prune": false
  },
  "experimental": {
    "openTelemetry": false
  },
  "lsp": true
}
